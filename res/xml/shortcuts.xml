<?xml version="1.0" encoding="utf-8"?>
<shortcuts
  xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut android:icon="@drawable/ic_new_session" android:enabled="true">
        <intent android:name="android.shortcut.conversation" android:targetPackage="com.termux" android:action="android.intent.action.RUN" android:targetClass="com.termux.app.TermuxActivity" />
    </shortcut>
    <shortcut android:icon="@drawable/ic_new_session" android:enabled="true">
        <intent android:name="android.shortcut.conversation" android:targetPackage="com.termux" android:action="android.intent.action.RUN" android:targetClass="com.termux.app.TermuxActivity">
            <extra android:name="com.termux.app.failsafe_session" android:value="true" />
        </intent>
    </shortcut>
    <shortcut android:icon="@drawable/ic_settings" android:enabled="true">
        <intent android:name="android.shortcut.conversation" android:targetPackage="com.termux" android:action="android.intent.action.VIEW" android:targetClass="com.termux.app.activities.SettingsActivity" />
    </shortcut>
</shortcuts>