        <Spinner android:textColor="#ffffffff" android:id="@id/driverSpinner" android:background="#aa000000" android:layout_width="fill_parent" android:layout_height="wrap_content" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CPU Core Policy" />
        <Spinner android:textColor="#ffffffff" android:id="@id/coresSpinner" android:background="#aa000000" android:layout_width="fill_parent" android:layout_height="wrap_content" />
    </LinearLayout>
</ScrollView>